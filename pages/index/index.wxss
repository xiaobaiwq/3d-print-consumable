.topbar {
  padding: 18rpx 20rpx 18rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.topbar-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.topbar-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #16202a;
}

.topbar-badge {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border: 1rpx solid #d8e0e8;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #7b8794;
  background: #f8fafc;
}

.quick-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
}

.quick-actions button::after,
.item-actions button::after,
.upload-row button::after,
.submit-btn::after {
  border: none;
}

.mini-btn {
  flex: 1;
  min-width: 0;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 60rpx;
  padding: 0 12rpx;
}

.more-btn {
  background: #f4f6f8;
  color: #52606d;
}

.more-dot-btn {
  flex: 0 0 84rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.filter-card,
.stats-grid,
.list-section {
  margin-top: 22rpx;
}

.filter-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.filter-tip {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #7b8794;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.input,
.picker-field {
  min-height: 86rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1f2933;
}

.input {
  width: 100%;
}

.compact-field {
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.search-field {
  grid-column: 1 / -1;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  padding: 18rpx 16rpx;
  background: linear-gradient(180deg, #ffffff, #f7fbff);
  border-radius: 22rpx;
}

.accent-orange {
  background: linear-gradient(180deg, #fff9f0, #fff3df);
}

.accent-red {
  background: linear-gradient(180deg, #fff5f5, #ffe9e9);
}

.stat-label {
  font-size: 21rpx;
  color: #52606d;
  line-height: 1.3;
}

.stat-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #16202a;
}

.item-card {
  margin-top: 18rpx;
}

.item-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #16202a;
}

.item-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.brand-chip {
  background: #e8f1ff;
  color: #2156a5;
}

.material-chip {
  background: #e9fbef;
  color: #177245;
}

.series-chip {
  background: #fff2d8;
  color: #9a5d00;
}

.stock-chip {
  flex-shrink: 0;
  height: fit-content;
  background: #edfdf3;
  color: #177245;
}

.stock-chip-danger {
  background: #fff1f0;
  color: #d14343;
}

.item-body {
  margin-top: 18rpx;
}

.item-content-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 16rpx;
}

.color-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.color-dot {
  width: 26rpx;
  height: 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d1d5db;
  background: #ffffff;
}

.large-dot {
  width: 44rpx;
  height: 44rpx;
}

.item-text {
  font-size: 28rpx;
  color: #364152;
}

.item-image {
  flex: 0 0 100px;
  width: 100px;
  height: 100px;
  border-radius: 22rpx;
  background: #eef2f7;
}

.editor-image {
  width: 100%;
  height: 280rpx;
  margin-top: 16rpx;
  border-radius: 22rpx;
  background: #eef2f7;
}

.item-info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.item-info-grid-side {
  flex: 1;
  margin-top: 0;
}

.info-pill {
  padding: 12rpx 18rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #52606d;
  background: #f8fafc;
}

.item-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.compact-btn {
  flex: 1;
  line-height: 72rpx;
  font-size: 26rpx;
}

.empty-card {
  margin-top: 18rpx;
  text-align: center;
  padding: 48rpx 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #16202a;
}

.empty-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.sheet-close {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #52606d;
  font-size: 24rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #52606d;
  font-weight: 600;
}

.form-picker {
  background: #ffffff;
}

.color-preview-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.color-code-input {
  flex: 1;
}

.swatch-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.swatch {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(31, 41, 51, 0.08);
}

.swatch-active {
  box-shadow: 0 0 0 4rpx rgba(47, 125, 246, 0.18);
  border-color: #2f7df6;
}

.upload-row {
  display: flex;
  gap: 14rpx;
}

.sheet-scroll {
  padding-bottom: 24rpx;
}

.sheet-footer {
  margin: 0 -24rpx;
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.submit-btn {
  width: 100%;
  margin-top: 0;
}

@media (max-width: 420px) {
  .form-grid {
    grid-template-columns: 1fr;
  }

  .filter-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-label {
    font-size: 20rpx;
  }

  .stat-value {
    font-size: 32rpx;
  }
}